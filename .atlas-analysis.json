  "keyFeatures": [
    "Auto-generated OpenAPI documentation via Go AST parsing",
    "Cron job tracking and management with execution logs",
    "Real-time system monitoring (CPU, memory, disk, network)",
    "Structured logging with request tracing and error tracking",
    "GDPR-compliant visitor analytics",
    "Versioned API routing system",
    "Built-in admin dashboard at /_/_",
    "PocketBase integration with auth and styling"
  ],
  "publicApiSurface": [
    "core.New(opts ...Option) *Server",
    "core.InDeveloperMode() Option",
    "core.InNormalMode() Option",
