    "api.NewSpecGeneratorWithInitializer(initializer func() (*APIVersionManager, error))",
    "jobs.GetManager() *JobManager",
    "jobs.RegisterJob(id, name, description, cronExpr string, handler func(*ExecutionLogger))",
    "jobs.ExecutionLogger.Start(message string)",
    "jobs.ExecutionLogger.Info(format string, args ...any)",
    "jobs.ExecutionLogger.Progress(format string, args ...any)",
    "jobs.ExecutionLogger.Success(format string, args ...any)",
    "jobs.ExecutionLogger.Error(format string, args ...any)",
    "jobs.ExecutionLogger.Statistics(stats map[string]interface{})",
